{
  "name": "@greatlhd/ailo-desktop",
  "version": "1.0.2",
  "description": "Ailo 超级端点 — 文件/代码/MCP/Web + 网页聊天。支持桌面模式与服务器模式。外部通道（飞书/微信）已内置在 Ailo 主进程。",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ailo-desktop": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node ../../scripts/copy-static.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@greatlhd/ailo-endpoint-sdk": "^1.0.2",
    "turndown": "^7.2.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
